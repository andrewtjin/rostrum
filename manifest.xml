        <bt:String id="Tip5" DefaultValue="Cycle the selected card&apos;s non-underlined text down a font size (8→7→6→5→4→Normal), keeping the underlined cut, highlights, cites, and headings full-size. Press again to shrink further." />
        <bt:String id="Tip6" DefaultValue="Collapse the selection per your Condense settings (merge paragraphs / pilcrows / retain paragraphs). Losslessly reversible with Uncondense." />
        <bt:String id="Tip7" DefaultValue="Reverse Condense — restore every paragraph break Rostrum marked." />
        <bt:String id="Tip8" DefaultValue="Reverse Shrink — reset the selected card&apos;s text back to its Normal size." />
        <bt:String id="Tip9" DefaultValue="Open Condense &amp; Shrink options — modes, the omission-marker editor, and one-click mode buttons. (App-wide settings live in the Settings group.)" />
        <bt:String id="Tip10" DefaultValue="Planned — extends today&apos;s Apply-Styles + condense work." />
        <bt:String id="Tip11" DefaultValue="Planned — the flowing / speech-doc surface." />
