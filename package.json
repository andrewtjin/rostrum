{
  "name": "rostrum-addin",
  "version": "0.3.0",
  "private": true,
  "description": "Rostrum — a desktop Word add-in suite for debaters. Flagship Invisibility Mode hides debate-card body text (keeping headings, cites, analytics, and highlights) and is natively reversible; ships with Condense & Shrink and a Settings pane.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "dev-server": "webpack serve --mode development",
    "watch": "webpack --mode development --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "gen:manifest": "tsx tools/gen-manifest.ts",
    "gen:manifest:prod": "tsx tools/gen-manifest.ts --out=dist/manifest.xml",
    "gen:icons": "node scripts/gen-icons.mjs",
    "audit:parts": "node scripts/auditDocxParts.mjs",
    "audit:separators": "node scripts/auditSeparators.mjs"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^25.9.1",
    "@types/office-js": "^1.0.377",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "copy-webpack-plugin": "^12.0.2",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "jszip": "^3.10.1",
    "office-addin-debugging": "^6.0.0",
    "office-addin-dev-certs": "^2.0.9",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
